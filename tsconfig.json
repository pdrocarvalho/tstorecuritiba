{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "noImplicitAny": false,
    "jsx": "react-jsx",
    "strict": true,
    "paths": {
      "@/*": ["./client/src/*"]
    }
  },
  "include": [
    "client/src/**/*",
    "server/**/*"
  ],
  "exclude": ["node_modules", "dist"]
}