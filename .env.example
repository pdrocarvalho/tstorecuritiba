# =============================================================================
# BANCO DE DADOS (PostgreSQL)
# =============================================================================
DATABASE_URL=postgresql://usuario:senha@host:5432/tstore_estoque

# =============================================================================
# AUTENTICAÇÃO
# =============================================================================
JWT_SECRET=troque-por-uma-chave-secreta-longa-e-aleatoria
MANAGER_PIN=0000

# =============================================================================
# GOOGLE (Sheets + Auth)
# =============================================================================
GOOGLE_CLIENT_ID=seu-client-id-do-google-aqui
GOOGLE_SERVICE_EMAIL=sua-service-account@projeto.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE_AQUI\n-----END PRIVATE KEY-----\n"

# ID da planilha de banco de dados interno (extraído da URL do Google Sheets)
# Exemplo: https://docs.google.com/spreadsheets/d/ESTE_TRECHO_AQUI/edit
DB_SPREADSHEET_ID=id-da-sua-planilha-aqui

# =============================================================================
# APLICAÇÃO
# =============================================================================
NODE_ENV=development
PORT=3000
